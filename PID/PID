void setWheelPWM(Wheel& w, int pwm) {
  pwm = constrain(pwm, -PWM_ABS_LIMIT, PWM_ABS_LIMIT);
  w.appliedPWM = pwm;

  if (pwm > 0) {
    digitalWrite(w.dir1Pin, HIGH);
    digitalWrite(w.dir2Pin, LOW);
    ledcWrite(w.pwmPin, pwm);
  } else if (pwm < 0) {
    digitalWrite(w.dir1Pin, LOW);
    digitalWrite(w.dir2Pin, HIGH);
    ledcWrite(w.pwmPin, -pwm);
  } else {
    digitalWrite(w.dir1Pin, LOW);
    digitalWrite(w.dir2Pin, LOW);
    ledcWrite(w.pwmPin, 0);
  }
}

void resetWheelPID(Wheel& w) {
  w.integral = 0.0f;
  w.lastError = 0.0f;
}

void resetAllWheelPID() {
  resetWheelPID(FL);
  resetWheelPID(FR);
  resetWheelPID(RL);
  resetWheelPID(RR);
}

void setWheelTarget(Wheel& w, float target) {
  w.targetRadS = target;
}

void stopAll() {
  poseMode = false;
  cmdVx = 0.0f;
  cmdVy = 0.0f;
  cmdWz = 0.0f;

  setWheelTarget(FL, 0);
  setWheelTarget(FR, 0);
  setWheelTarget(RL, 0);
  setWheelTarget(RR, 0);

  resetAllWheelPID();

  setWheelPWM(FL, 0);
  setWheelPWM(FR, 0);
  setWheelPWM(RL, 0);
  setWheelPWM(RR, 0);
}

float countsToRadS(long deltaCounts) {
  return ((float)deltaCounts / ENCODER_PPR) * 2.0f * PI / CONTROL_DT_S;
}

void updateWheelSpeed(Wheel& w) {
  long countNow;

  noInterrupts();
  countNow = *(w.encCount);
  interrupts();

  long delta = countNow - w.lastCount;

  w.lastCount = countNow;
  w.lastDelta = delta;

  w.rawRadS = countsToRadS(delta);
  w.filtRadS = FILTER_ALPHA * w.rawRadS + (1.0f - FILTER_ALPHA) * w.filtRadS;
}

void updateWheelPID(Wheel& w) {
  if (abs(w.targetRadS) < 0.01f) {
    resetWheelPID(w);
    setWheelPWM(w, 0);
    return;
  }

  float error = w.targetRadS - w.filtRadS;

  w.integral += error * CONTROL_DT_S;
  w.integral = constrain(w.integral, -w.integralLimit, w.integralLimit);

  float derivative = (error - w.lastError) / CONTROL_DT_S;
  w.lastError = error;

  float pidOutput = (w.Kp * error) + (w.Ki * w.integral) + (w.Kd * derivative);

  int feedforward = 0;

  if (w.targetRadS > 0) feedforward = w.basePWM;
  else if (w.targetRadS < 0) feedforward = -w.basePWM;

  int pwmCommand = feedforward + (int)pidOutput;
  pwmCommand = constrain(pwmCommand, -w.maxPWM, w.maxPWM);

  setWheelPWM(w, pwmCommand);
}

void setBodyVelocityTargets(float vx, float vy, float wz) {
  cmdVx = vx;
  cmdVy = vy;
  cmdWz = wz;

  float wFL = (vx - vy - K_M * wz) / WHEEL_RADIUS_M;
  float wFR = (vx + vy + K_M * wz) / WHEEL_RADIUS_M;
  float wRL = (vx + vy - K_M * wz) / WHEEL_RADIUS_M;
  float wRR = (vx - vy + K_M * wz) / WHEEL_RADIUS_M;

  setWheelTarget(FL, wFL);
  setWheelTarget(FR, wFR);
  setWheelTarget(RL, wRL);
  setWheelTarget(RR, wRR);
}

// ============================================================
// ODOMETRY + OUTER POSE LOOP
// ============================================================

void updateOdometryFromWheels() {
  float wFL = FL.filtRadS;
  float wFR = FR.filtRadS;
  float wRL = RL.filtRadS;
  float wRR = RR.filtRadS;

  float vxBody = (WHEEL_RADIUS_M / 4.0f) * (wFL + wFR + wRL + wRR);
  float vyBody = (WHEEL_RADIUS_M / 4.0f) * (-wFL + wFR + wRL - wRR);

  vxBody *= ODOM_X_SCALE;
  vyBody *= ODOM_Y_SCALE;

  float yawRad = degToRad(yawDeg);
  float c = cosf(yawRad);
  float s = sinf(yawRad);

  float vxWorld = vxBody * c - vyBody * s;
  float vyWorld = vxBody * s + vyBody * c;

  poseX += vxWorld * CONTROL_DT_S;
  poseY += vyWorld * CONTROL_DT_S;
}

float updatePIDTerm(float error, float &integral, float &lastError, float kp, float ki, float kd, float iLimit) {
  integral += error * CONTROL_DT_S;
  integral = constrain(integral, -iLimit, iLimit);

  float derivative = (error - lastError) / CONTROL_DT_S;
  lastError = error;

  return (kp * error) + (ki * integral) + (kd * derivative);
}

void updatePoseLoop() {
  if (!poseMode) {
    return;
  }

  float errXWorld = targetX - poseX;
  float errYWorld = targetY - poseY;

  float yawRad = degToRad(yawDeg);
  float c = cosf(yawRad);
  float s = sinf(yawRad);

  float errXBody = c * errXWorld + s * errYWorld;
  float errYBody = -s * errXWorld + c * errYWorld;

  float yawErrDeg = wrapDeg(poseYawTargetDeg - yawDeg);
  float yawErrRad = degToRad(yawErrDeg);

  bool posDone = hypotf(errXWorld, errYWorld) < POS_TOL_M;
  bool yawDone = fabsf(yawErrDeg) < YAW_TOL_DEG;

  if (posDone && yawDone) {
    poseMode = false;
    resetOuterPID();
    setBodyVelocityTargets(0, 0, 0);
    return;
  }

  float vxCmd = updatePIDTerm(errXBody, posIntX, posLastErrX, posKpX, posKiX, posKdX, posIntegralLimit);
  float vyCmd = updatePIDTerm(errYBody, posIntY, posLastErrY, posKpY, posKiY, posKdY, posIntegralLimit);
  float wzCmd = updatePIDTerm(yawErrRad, yawInt, yawLastErrRad, yawKp, yawKi, yawKd, yawIntegralLimit);

  vxCmd = constrain(vxCmd, -MAX_VX, MAX_VX);
  vyCmd = constrain(vyCmd, -MAX_VY, MAX_VY);
  wzCmd = constrain(wzCmd, -MAX_WZ, MAX_WZ);

  setBodyVelocityTargets(vxCmd, vyCmd, wzCmd);
}

void updateAllControl() {
  updateWheelSpeed(FL);
  updateWheelSpeed(FR);
  updateWheelSpeed(RL);
  updateWheelSpeed(RR);

  updateOdometryFromWheels();
  updatePoseLoop();

  updateWheelPID(FL);
  updateWheelPID(FR);
  updateWheelPID(RL);
  updateWheelPID(RR);
}

void startPoseMove(float x, float y, float yawTargetDeg) {
  targetX = x;
  targetY = y;
  poseYawTargetDeg = wrapDeg(yawTargetDeg);
  poseMode = true;
  resetOuterPID();
}

