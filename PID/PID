    .row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
    table{width:100%;border-collapse:collapse;font-size:14px}
    td,th{border-bottom:1px solid #333;padding:8px;text-align:right}
    td:first-child,th:first-child{text-align:left}
    canvas{width:100%;height:170px;background:#080808;border:1px solid #333;border-radius:6px}
    .big{font-size:20px;color:#93c5fd;font-weight:bold}.hint{color:#aaa;font-size:13px}.status{color:#22c55e;font-size:13px}
    @media(max-width:760px){.grid{grid-template-columns:1fr}.controls{grid-template-columns:repeat(2,1fr)}.stop{grid-column:span 2}table{font-size:12px}input{width:64px}}
  </style>
</head>
<body>
<header>Mecanum Pose PID - Cascaded Control</header>
<div class="wrap">
  <div class="panel">
    <b>Status</b>
    <div class="row">
      <span>Mode: <span class="big" id="mode">--</span></span>
      <span>X: <span class="big" id="x">--</span></span>
      <span>Y: <span class="big" id="y">--</span></span>
      <span>Yaw: <span class="big" id="yaw">--</span></span>
      <span>IMU: <span class="big" id="imu">--</span></span>
    </div>
    <div class="row">
      <span>Target X: <span id="tx">--</span></span>
      <span>Target Y: <span id="ty">--</span></span>
      <span>Target Yaw: <span id="tyaw">--</span></span>
      <span>cmd vx: <span id="cvx">--</span></span>
      <span>cmd vy: <span id="cvy">--</span></span>
      <span>cmd wz: <span id="cwz">--</span></span>
      <span>Odom X scale: <span id="odomx">--</span></span>
      <span>Odom Y scale: <span id="odomy">--</span></span>
    </div>
  </div>

  <div class="panel">
    <b>Pose Command</b>
    <div class="row">
      <label>X m</label><input id="targetX" type="number" value="0.20" step="0.01">
      <label>Y m</label><input id="targetY" type="number" value="0.00" step="0.01">
      <label>Yaw deg</label><input id="targetYaw" type="number" value="0" step="1">
      <button class="apply" onclick="goPose()">Go To Pose</button>
      <button class="secondary" onclick="zeroPose()">Zero Pose</button>
      <button class="secondary" onclick="imuCal()">IMU Cal</button>
    </div>
    <div class="controls">
      <button onclick="manual('fwd')">Forward</button>
      <button onclick="manual('cw')">CW</button>
      <button onclick="manual('right')">Right</button>
      <button onclick="manual('left')">Left</button>
      <button onclick="manual('ccw')">CCW</button>
      <button onclick="manual('back')">Backward</button>
      <button class="stop" onclick="stopRobot()">STOP</button>
    </div>
    <div class="row">
      <label>Manual speed rad/s</label><input id="manualSpeed" type="number" value="3.0" step="0.1">
      <span class="hint">Use Go To Pose for outer-loop tuning. Manual buttons bypass pose mode.</span>
    </div>
  </div>

  <div class="panel">
    <div class="row">
      <b>Outer Loop Tuning</b>
      <button class="apply" onclick="applyOuter()">Apply Outer</button>
      <button onclick="loadOuter()">Reload</button>
      <span id="outerStatus" class="status"></span>
    </div>
    <table>
      <tbody id="outerBody"></tbody>
    </table>
  </div>

  <div class="panel">
    <b>Wheel Data</b>
    <table>
      <thead><tr><th>Wheel</th><th>Target</th><th>Actual</th><th>Error</th><th>Raw</th><th>D</th><th>PWM</th></tr></thead>
      <tbody id="wheelBody"></tbody>
    </table>
  </div>

  <div class="panel">
    <div class="row">
      <b>Inner Wheel Tuning</b>
      <button class="apply" onclick="applyWheelParams()">Apply Wheels</button>
      <button onclick="loadWheelParams()">Reload</button>
      <span id="wheelStatus" class="status"></span>
    </div>
    <table>
      <thead><tr><th>Wheel</th><th>Kp</th><th>Ki</th><th>Kd</th><th>Base</th><th>Max</th><th>I Lim</th></tr></thead>
      <tbody id="paramsBody"></tbody>
    </table>
  </div>

  <div class="grid">
    <div class="panel"><b>X Response</b><canvas id="plotX"></canvas></div>
    <div class="panel"><b>Y Response</b><canvas id="plotY"></canvas></div>
    <div class="panel"><b>Yaw Response</b><canvas id="plotYaw"></canvas></div>
    <div class="panel"><b>Wheel Speeds</b><canvas id="plotWheel"></canvas></div>
  </div>
</div>

<script>
const wheels=["FL","FR","RL","RR"];
const wheelParams=["kp","ki","kd","base","max","ilim"];
const outerParams=[
  ["kpx","Kp X"],["kix","Ki X"],["kdx","Kd X"],
  ["kpy","Kp Y"],["kiy","Ki Y"],["kdy","Kd Y"],
  ["yawkp","Yaw Kp"],["yawki","Yaw Ki"],["yawkd","Yaw Kd"],
  ["maxvx","Max vx"],["maxvy","Max vy"],["maxwz","Max wz"],
  ["odomx","Odom X scale"],["odomy","Odom Y scale"],
  ["postol","Pos tol"],["yawtol","Yaw tol"],
  ["posilim","Pos I lim"],["yawilim","Yaw I lim"],["yawsign","Yaw sign"]
];
const hist={x:[],tx:[],y:[],ty:[],yaw:[],tyaw:[],fl:[],fr:[],rl:[],rr:[]};
const maxPoints=150;
function val(id){return parseFloat(document.getElementById(id).value||"0")}
function push(a,v){a.push(v);if(a.length>maxPoints)a.shift()}
function goPose(){fetch(`/pose?x=${val("targetX")}&y=${val("targetY")}&yaw=${val("targetYaw")}`)}
function zeroPose(){fetch("/zeroPose")}
function imuCal(){fetch("/imucal")}
function stopRobot(){fetch("/stop")}
function manual(c){fetch(`/move?cmd=${c}&s=${val("manualSpeed")}`)}
function draw(id, series){
  const c=document.getElementById(id),ctx=c.getContext("2d"),dpr=window.devicePixelRatio||1,w=c.clientWidth,h=c.clientHeight;
  if(c.width!==w*dpr||c.height!==h*dpr){c.width=w*dpr;c.height=h*dpr}
  ctx.setTransform(dpr,0,0,dpr,0,0);ctx.clearRect(0,0,w,h);ctx.strokeStyle="#333";ctx.lineWidth=1;
  for(let i=0;i<5;i++){let y=h*i/4;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(w,y);ctx.stroke()}
  let vals=[];series.forEach(s=>vals=vals.concat(s.data));let m=Math.max(0.1,...vals.map(v=>Math.abs(v)));
  series.forEach(s=>{ctx.strokeStyle=s.color;ctx.lineWidth=2;ctx.beginPath();s.data.forEach((v,i)=>{let x=i*w/(maxPoints-1),y=h/2-(v/m)*(h*0.42);if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y)});ctx.stroke()});
}
async function poll(){
  try{
    const r=await fetch("/data");const d=await r.json();
    document.getElementById("mode").textContent=d.poseMode?"POSE":"MANUAL";
    document.getElementById("x").textContent=d.pose.x.toFixed(3);
    document.getElementById("y").textContent=d.pose.y.toFixed(3);
    document.getElementById("yaw").textContent=d.pose.yaw.toFixed(1);
    document.getElementById("imu").textContent=d.imu?"OK":"NO";
    document.getElementById("tx").textContent=d.target.x.toFixed(3);
    document.getElementById("ty").textContent=d.target.y.toFixed(3);
    document.getElementById("tyaw").textContent=d.target.yaw.toFixed(1);
    document.getElementById("cvx").textContent=d.cmd.vx.toFixed(3);
    document.getElementById("cvy").textContent=d.cmd.vy.toFixed(3);
    document.getElementById("cwz").textContent=d.cmd.wz.toFixed(3);
    document.getElementById("odomx").textContent=d.odom.x.toFixed(3);
    document.getElementById("odomy").textContent=d.odom.y.toFixed(3);
    push(hist.x,d.pose.x);push(hist.tx,d.target.x);push(hist.y,d.pose.y);push(hist.ty,d.target.y);push(hist.yaw,d.pose.yaw/90);push(hist.tyaw,d.target.yaw/90);
    let html="";
    for(const w of wheels){const q=d.wheels[w];html+=`<tr><td>${w}</td><td>${q.t.toFixed(2)}</td><td>${q.a.toFixed(2)}</td><td>${(q.t-q.a).toFixed(2)}</td><td>${q.raw.toFixed(2)}</td><td>${q.d}</td><td>${q.pwm}</td></tr>`}
    document.getElementById("wheelBody").innerHTML=html;
    push(hist.fl,d.wheels.FL.a);push(hist.fr,d.wheels.FR.a);push(hist.rl,d.wheels.RL.a);push(hist.rr,d.wheels.RR.a);
    draw("plotX",[{data:hist.tx,color:"#ffcc00"},{data:hist.x,color:"#22c55e"}]);
    draw("plotY",[{data:hist.ty,color:"#ffcc00"},{data:hist.y,color:"#22c55e"}]);
    draw("plotYaw",[{data:hist.tyaw,color:"#ffcc00"},{data:hist.yaw,color:"#22c55e"}]);
    draw("plotWheel",[{data:hist.fl,color:"#22c55e"},{data:hist.fr,color:"#38bdf8"},{data:hist.rl,color:"#f97316"},{data:hist.rr,color:"#e879f9"}]);
  }catch(e){}
  setTimeout(poll,100);
}
function makeWheelTable(data){
  let html="";
  for(const w of wheels){html+=`<tr><td>${w}</td>`;for(const p of wheelParams){html+=`<td><input id="${w}_${p}" type="number" step="0.01" value="${data[w][p]}"></td>`}html+="</tr>"}
  document.getElementById("paramsBody").innerHTML=html;
}
async function loadWheelParams(){try{const r=await fetch("/params");makeWheelTable(await r.json());document.getElementById("wheelStatus").textContent="Loaded"}catch(e){}}
async function applyWheelParams(){document.getElementById("wheelStatus").textContent="Applying...";for(const w of wheels){for(const p of wheelParams){await fetch(`/setParam?wheel=${w}&param=${p}&value=${document.getElementById(`${w}_${p}`).value}`)}}document.getElementById("wheelStatus").textContent="Applied"}
function makeOuterTable(data){
  let html="";
  for(let i=0;i<outerParams.length;i+=3){html+="<tr>";for(let j=0;j<3;j++){const item=outerParams[i+j];if(item){html+=`<td>${item[1]}</td><td><input id="outer_${item[0]}" type="number" step="0.001" value="${data[item[0]]}"></td>`}}html+="</tr>"}
  document.getElementById("outerBody").innerHTML=html;
}
async function loadOuter(){try{const r=await fetch("/outer");makeOuterTable(await r.json());document.getElementById("outerStatus").textContent="Loaded"}catch(e){}}
async function applyOuter(){document.getElementById("outerStatus").textContent="Applying...";for(const p of outerParams){await fetch(`/setOuter?param=${p[0]}&value=${document.getElementById(`outer_${p[0]}`).value}`)}document.getElementById("outerStatus").textContent="Applied"}
loadWheelParams();loadOuter();poll();
</script>
</body>
</html>
)rawliteral";

// ============================================================
// JSON HELPERS + ROUTES
// ============================================================

void sendWheelJsonPart(const Wheel& w, String& json) {
  json += "\"";
  json += w.name;
  json += "\":{";
  json += "\"t\":" + String(w.targetRadS, 3);
  json += ",\"a\":" + String(w.filtRadS, 3);
  json += ",\"raw\":" + String(w.rawRadS, 3);
  json += ",\"d\":" + String(w.lastDelta);
  json += ",\"pwm\":" + String(w.appliedPWM);
  json += "}";
}

void handleData() {
  String json = "{";
  json += "\"poseMode\":" + String(poseMode ? "true" : "false") + ",";
  json += "\"imu\":" + String(imuOk ? "true" : "false") + ",";
  json += "\"pose\":{\"x\":" + String(poseX, 4) + ",\"y\":" + String(poseY, 4) + ",\"yaw\":" + String(yawDeg, 3) + "},";
  json += "\"target\":{\"x\":" + String(targetX, 4) + ",\"y\":" + String(targetY, 4) + ",\"yaw\":" + String(poseYawTargetDeg, 3) + "},";
  json += "\"cmd\":{\"vx\":" + String(cmdVx, 4) + ",\"vy\":" + String(cmdVy, 4) + ",\"wz\":" + String(cmdWz, 4) + "},";
  json += "\"odom\":{\"x\":" + String(ODOM_X_SCALE, 4) + ",\"y\":" + String(ODOM_Y_SCALE, 4) + "},";
  json += "\"wheels\":{";
  sendWheelJsonPart(FL, json); json += ",";
  sendWheelJsonPart(FR, json); json += ",";
  sendWheelJsonPart(RL, json); json += ",";
  sendWheelJsonPart(RR, json);
  json += "}}";

  server.send(200, "application/json", json);
}

void sendParamJsonPart(const Wheel& w, String& json) {
  json += "\"";
  json += w.name;
  json += "\":{";
  json += "\"kp\":" + String(w.Kp, 3);
  json += ",\"ki\":" + String(w.Ki, 3);
  json += ",\"kd\":" + String(w.Kd, 3);
  json += ",\"base\":" + String(w.basePWM);
  json += ",\"max\":" + String(w.maxPWM);
  json += ",\"ilim\":" + String(w.integralLimit, 3);
  json += "}";
}

void handleParams() {
  String json = "{";
  sendParamJsonPart(FL, json); json += ",";
  sendParamJsonPart(FR, json); json += ",";
  sendParamJsonPart(RL, json); json += ",";
  sendParamJsonPart(RR, json);
  json += "}";

  server.send(200, "application/json", json);
}

void handleOuter() {
  String json = "{";
  json += "\"kpx\":" + String(posKpX, 4);
  json += ",\"kix\":" + String(posKiX, 4);
  json += ",\"kdx\":" + String(posKdX, 4);
  json += ",\"kpy\":" + String(posKpY, 4);
  json += ",\"kiy\":" + String(posKiY, 4);
  json += ",\"kdy\":" + String(posKdY, 4);
  json += ",\"yawkp\":" + String(yawKp, 4);
  json += ",\"yawki\":" + String(yawKi, 4);
  json += ",\"yawkd\":" + String(yawKd, 4);
  json += ",\"maxvx\":" + String(MAX_VX, 4);
  json += ",\"maxvy\":" + String(MAX_VY, 4);
  json += ",\"maxwz\":" + String(MAX_WZ, 4);
  json += ",\"odomx\":" + String(ODOM_X_SCALE, 4);
  json += ",\"odomy\":" + String(ODOM_Y_SCALE, 4);
  json += ",\"postol\":" + String(POS_TOL_M, 4);
  json += ",\"yawtol\":" + String(YAW_TOL_DEG, 4);
  json += ",\"posilim\":" + String(posIntegralLimit, 4);
  json += ",\"yawilim\":" + String(yawIntegralLimit, 4);
  json += ",\"yawsign\":" + String(YAW_SIGN, 1);
  json += "}";

  server.send(200, "application/json", json);
}

void handleSetParam() {
  Wheel* w = getWheelByName(server.arg("wheel"));

  if (w == nullptr) {
    server.send(400, "text/plain", "Unknown wheel");
    return;
  }

  if (!setWheelParam(*w, server.arg("param"), server.arg("value").toFloat())) {
    server.send(400, "text/plain", "Unknown parameter");
    return;
  }

  server.send(200, "text/plain", "OK");
}

void handleSetOuter() {
  if (!setOuterParam(server.arg("param"), server.arg("value").toFloat())) {
    server.send(400, "text/plain", "Unknown outer parameter");
    return;
  }

  server.send(200, "text/plain", "OK");
}

void handlePose() {
  float x = server.arg("x").toFloat();
  float y = server.arg("y").toFloat();
  float yaw = server.arg("yaw").toFloat();

  x = constrain(x, -5.0f, 5.0f);
  y = constrain(y, -5.0f, 5.0f);
  yaw = constrain(yaw, -180.0f, 180.0f);

  startPoseMove(x, y, yaw);
  server.send(200, "text/plain", "POSE");
}

void handleMove() {
  poseMode = false;
  resetOuterPID();

  String cmd = server.arg("cmd");
  float s = fabsf(server.arg("s").toFloat());
  s = constrain(s, 0.0f, 12.0f);

  if (cmd == "fwd") {
    setWheelTarget(FL, +s); setWheelTarget(FR, +s); setWheelTarget(RL, +s); setWheelTarget(RR, +s);
  } else if (cmd == "back") {
    setWheelTarget(FL, -s); setWheelTarget(FR, -s); setWheelTarget(RL, -s); setWheelTarget(RR, -s);
  } else if (cmd == "right") {
    setWheelTarget(FL, +s); setWheelTarget(FR, -s); setWheelTarget(RL, -s); setWheelTarget(RR, +s);
  } else if (cmd == "left") {
    setWheelTarget(FL, -s); setWheelTarget(FR, +s); setWheelTarget(RL, +s); setWheelTarget(RR, -s);
  } else if (cmd == "cw") {
    setWheelTarget(FL, +s); setWheelTarget(FR, -s); setWheelTarget(RL, +s); setWheelTarget(RR, -s);
  } else if (cmd == "ccw") {
    setWheelTarget(FL, -s); setWheelTarget(FR, +s); setWheelTarget(RL, -s); setWheelTarget(RR, +s);
  }

  server.send(200, "text/plain", "OK");
}

void handleStop() {
  stopAll();
  server.send(200, "text/plain", "STOP");
}

void handleZeroPose() {
  stopAll();
  zeroPose();
  server.send(200, "text/plain", "ZERO");
}

void handleImuCal() {
  stopAll();
  calibrateIMU(1200);
  server.send(200, "text/plain", "IMU CAL");
}

// ============================================================
// SETUP HELPERS
// ============================================================

void setupWheelPins(const Wheel& w) {
  pinMode(w.dir1Pin, OUTPUT);
  pinMode(w.dir2Pin, OUTPUT);

  digitalWrite(w.dir1Pin, LOW);
  digitalWrite(w.dir2Pin, LOW);

  pinMode(w.encAPin, INPUT);
  pinMode(w.encBPin, INPUT);

  bool pwmOk = ledcAttach(w.pwmPin, PWM_FREQ_HZ, PWM_RESOLUTION);

  if (!pwmOk) {
    Serial.print("ERROR: ledcAttach failed for ");
    Serial.println(w.name);

    while (true) delay(1000);
  }

  ledcWrite(w.pwmPin, 0);
}

void initEncoderState(Wheel& w) {
  *(w.lastState) = (digitalRead(w.encAPin) << 1) | digitalRead(w.encBPin);
}

void setupWiFi() {
  WiFi.mode(WIFI_STA);
  WiFi.config(localIP, gateway, subnet);
  WiFi.begin(WIFI_SSID, WIFI_PASS);

  Serial.print("Connecting to WiFi");

  uint32_t startTime = millis();

  while (WiFi.status() != WL_CONNECTED && millis() - startTime < 20000) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();

  if (WiFi.status() == WL_CONNECTED) {
    Serial.print("Connected. Open: http://");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("WiFi failed. Starting backup AP DeliveryRobot_AP / 12345678");
    WiFi.mode(WIFI_AP);
    WiFi.softAP("DeliveryRobot_AP", "12345678");
    Serial.print("Open: http://");
    Serial.println(WiFi.softAPIP());
  }
}

// ============================================================
// SETUP + LOOP
// ============================================================

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("Mecanum Pose Cascaded PID GUI");

  setupWheelPins(FL);
  setupWheelPins(FR);
  setupWheelPins(RL);
  setupWheelPins(RR);

  initEncoderState(FL);
  initEncoderState(FR);
  initEncoderState(RL);
  initEncoderState(RR);

  attachInterrupt(digitalPinToInterrupt(FR_ENC_A), isrFR, CHANGE);
  attachInterrupt(digitalPinToInterrupt(FR_ENC_B), isrFR, CHANGE);

  attachInterrupt(digitalPinToInterrupt(FL_ENC_A), isrFL, CHANGE);
  attachInterrupt(digitalPinToInterrupt(FL_ENC_B), isrFL, CHANGE);

  attachInterrupt(digitalPinToInterrupt(RR_ENC_A), isrRR, CHANGE);
  attachInterrupt(digitalPinToInterrupt(RR_ENC_B), isrRR, CHANGE);

  attachInterrupt(digitalPinToInterrupt(RL_ENC_A), isrRL, CHANGE);
  attachInterrupt(digitalPinToInterrupt(RL_ENC_B), isrRL, CHANGE);

  stopAll();

  imuOk = bmi160Init();

  if (imuOk) {
    Serial.println("BMI160 initialized. Run IMU Cal from GUI before testing.");
  } else {
    Serial.println("IMU failed. Yaw will not be reliable.");
  }

  setupWiFi();

  server.on("/", []() { server.send_P(200, "text/html", MAIN_page); });
  server.on("/data", handleData);
  server.on("/params", handleParams);
  server.on("/outer", handleOuter);
  server.on("/setParam", handleSetParam);
  server.on("/setOuter", handleSetOuter);
  server.on("/pose", handlePose);
  server.on("/move", handleMove);
  server.on("/stop", handleStop);
  server.on("/zeroPose", handleZeroPose);
  server.on("/imucal", handleImuCal);

  server.begin();
  Serial.println("Web server started.");
}

void loop() {
  static uint32_t lastControl = 0;
  static uint32_t lastImu = 0;

  server.handleClient();

  uint32_t now = millis();

  if (now - lastImu >= 10) {
    lastImu = now;
    updateIMU();
  }

  if (now - lastControl >= CONTROL_DT_MS) {
    lastControl = now;
    updateAllControl();
  }
}
