void setupWheelPins(const Wheel& w) {
  pinMode(w.dir1Pin, OUTPUT);
  pinMode(w.dir2Pin, OUTPUT);

  digitalWrite(w.dir1Pin, LOW);
  digitalWrite(w.dir2Pin, LOW);

  pinMode(w.encAPin, INPUT);
  pinMode(w.encBPin, INPUT);

  bool pwmOk = ledcAttach(w.pwmPin, PWM_FREQ_HZ, PWM_RESOLUTION);

  if (!pwmOk) {
    Serial.print("ERROR: ledcAttach failed for ");
    Serial.println(w.name);

    while (true) delay(1000);
  }

  ledcWrite(w.pwmPin, 0);
}

void initEncoderState(Wheel& w) {
  *(w.lastState) = (digitalRead(w.encAPin) << 1) | digitalRead(w.encBPin);
}

const char* wifiStatusText(wl_status_t status) {
  switch (status) {
    case WL_IDLE_STATUS: return "idle";
    case WL_NO_SSID_AVAIL: return "SSID not found";
    case WL_SCAN_COMPLETED: return "scan completed";
    case WL_CONNECTED: return "connected";
    case WL_CONNECT_FAILED: return "connection failed (check password/security)";
    case WL_CONNECTION_LOST: return "connection lost";
    case WL_DISCONNECTED: return "disconnected";
    default: return "unknown";
  }
}

void scanForConfiguredWiFi() {
  Serial.print("Scanning for SSID: ");
  Serial.println(WIFI_SSID);

  int networkCount = WiFi.scanNetworks(false, true);
  bool found = false;

  if (networkCount <= 0) {
    Serial.println("No WiFi networks found. Check antenna, distance, and 2.4 GHz coverage.");
  } else {
    for (int i = 0; i < networkCount; i++) {
      if (WiFi.SSID(i) == WIFI_SSID) {
        found = true;
        Serial.print("Target SSID found. RSSI=");
        Serial.print(WiFi.RSSI(i));
        Serial.print(" dBm, channel=");
        Serial.println(WiFi.channel(i));
      }
    }
  }

  if (!found) {
    Serial.println("Target SSID was not found. Check spelling and ensure 2.4 GHz is enabled.");
  }

  WiFi.scanDelete();
}

void setupWiFi() {
  WiFi.mode(WIFI_STA);
#if defined(ESP32)
  WiFi.setSleep(false);
#elif defined(ESP8266)
  WiFi.setSleepMode(WIFI_NONE_SLEEP);
#endif

  Serial.print("ESP WiFi MAC: ");
  Serial.println(WiFi.macAddress());
  scanForConfiguredWiFi();

  WiFi.config(localIP, gateway, subnet);
  WiFi.begin(WIFI_SSID, WIFI_PASS);

  Serial.print("Connecting to WiFi");

  uint32_t startTime = millis();

  while (WiFi.status() != WL_CONNECTED && millis() - startTime < 20000) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();

  if (WiFi.status() == WL_CONNECTED) {
    stationWasConnected = true;
    Serial.print("Connected. Open: http://");
    Serial.println(WiFi.localIP());
  } else {
    usingBackupAp = true;
    wl_status_t status = WiFi.status();
    Serial.print("Station connection status: ");
    Serial.print(wifiStatusText(status));
    Serial.print(" (");
    Serial.print((int)status);
    Serial.println(")");
    Serial.println("WiFi failed. Starting backup AP DeliveryRobot_AP / 12345678");
    WiFi.mode(WIFI_AP);
    WiFi.softAP("DeliveryRobot_AP", "12345678");
    Serial.print("Open: http://");
    Serial.println(WiFi.softAPIP());
  }
}

void maintainWiFi() {
  if (usingBackupAp) {
    return;
  }

  if (WiFi.status() == WL_CONNECTED) {
    stationWasConnected = true;
    return;
  }

  if (stationWasConnected) {
    stationWasConnected = false;
    stopAll();
    Serial.println("WiFi disconnected. Robot stopped.");
  }

  static uint32_t lastReconnectAttemptMs = 0;
  uint32_t now = millis();
  if (now - lastReconnectAttemptMs < 5000) {
    return;
  }

  lastReconnectAttemptMs = now;
  WiFi.disconnect();
  WiFi.config(localIP, gateway, subnet);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  Serial.println("Attempting WiFi reconnection...");
}

// ============================================================
// SETUP + LOOP
// ============================================================

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("Mecanum Pose Cascaded PID GUI");

  setupWheelPins(FL);
  setupWheelPins(FR);
  setupWheelPins(RL);
  setupWheelPins(RR);

  initEncoderState(FL);
  initEncoderState(FR);
  initEncoderState(RL);
  initEncoderState(RR);

  attachInterrupt(digitalPinToInterrupt(FR_ENC_A), isrFR, CHANGE);
  attachInterrupt(digitalPinToInterrupt(FR_ENC_B), isrFR, CHANGE);

  attachInterrupt(digitalPinToInterrupt(FL_ENC_A), isrFL, CHANGE);
  attachInterrupt(digitalPinToInterrupt(FL_ENC_B), isrFL, CHANGE);

  attachInterrupt(digitalPinToInterrupt(RR_ENC_A), isrRR, CHANGE);
  attachInterrupt(digitalPinToInterrupt(RR_ENC_B), isrRR, CHANGE);

  attachInterrupt(digitalPinToInterrupt(RL_ENC_A), isrRL, CHANGE);
  attachInterrupt(digitalPinToInterrupt(RL_ENC_B), isrRL, CHANGE);

  stopAll();

  imuOk = bmi160Init();

  if (imuOk) {
    Serial.println("BMI160 initialized. Run IMU Cal from GUI before testing.");
  } else {
    Serial.println("IMU failed. Yaw will not be reliable.");
  }

  setupWiFi();

  server.on("/", []() { server.send_P(200, "text/html", MAIN_page); });
  server.on("/data", handleData);
  server.on("/params", handleParams);
  server.on("/outer", handleOuter);
  server.on("/setParam", handleSetParam);
  server.on("/setOuter", handleSetOuter);
  server.on("/operatorRequest", handleOperatorRequest);
  server.on("/operatorAck", handleOperatorAck);
  server.on("/rosStatus", handleRosStatus);
  server.on("/pose", handlePose);
  server.on("/move", handleMove);
  server.on("/stop", handleStop);
  server.on("/zeroPose", handleZeroPose);
  server.on("/imucal", handleImuCal);

  server.begin();
  Serial.println("Web server started.");
}

void loop() {
  static uint32_t lastControl = 0;
  static uint32_t lastImu = 0;

  server.handleClient();
  maintainWiFi();
  maintainRosOwnership();

  uint32_t now = millis();

  if (now - lastImu >= 10) {
    lastImu = now;
    updateIMU();
  }

  if (now - lastControl >= CONTROL_DT_MS) {
    lastControl = now;
    updateAllControl();
  }
}
