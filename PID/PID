}

// ============================================================
// BMI160 LOW LEVEL
// ============================================================

bool i2cWrite8(uint8_t addr, uint8_t reg, uint8_t value) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(value);
  return Wire.endTransmission() == 0;
}

bool i2cReadBytes(uint8_t addr, uint8_t reg, uint8_t* data, uint8_t len) {
  Wire.beginTransmission(addr);
  Wire.write(reg);

  if (Wire.endTransmission(false) != 0) {
    return false;
  }

  uint8_t received = Wire.requestFrom(addr, len);

  if (received != len) {
    return false;
  }

  for (uint8_t i = 0; i < len; i++) {
    data[i] = Wire.read();
  }

  return true;
}

uint8_t i2cRead8(uint8_t addr, uint8_t reg) {
  uint8_t value = 0xFF;
  i2cReadBytes(addr, reg, &value, 1);
  return value;
}

bool bmi160Detect() {
  uint8_t id1 = i2cRead8(BMI160_ADDR_1, BMI160_REG_CHIP_ID);
  uint8_t id2 = i2cRead8(BMI160_ADDR_2, BMI160_REG_CHIP_ID);

  if (id1 == 0xD1) {
    bmiAddr = BMI160_ADDR_1;
    return true;
  }

  if (id2 == 0xD1) {
    bmiAddr = BMI160_ADDR_2;
    return true;
  }

  return false;
}

bool bmi160Init() {
  Wire.begin(I2C_SDA_PIN, I2C_SCL_PIN);
  Wire.setClock(400000);
  delay(100);

  if (!bmi160Detect()) {
    Serial.println("BMI160 not detected.");
    return false;
  }

  Serial.print("BMI160 detected at 0x");
  Serial.println(bmiAddr, HEX);

  i2cWrite8(bmiAddr, BMI160_REG_CMD, BMI160_CMD_SOFT_RESET);
  delay(100);

  if (!bmi160Detect()) {
    Serial.println("BMI160 disappeared after reset.");
    return false;
  }

  i2cWrite8(bmiAddr, BMI160_REG_CMD, BMI160_CMD_ACC_NORMAL);
  delay(50);
  i2cWrite8(bmiAddr, BMI160_REG_CMD, BMI160_CMD_GYR_NORMAL);
  delay(100);

  i2cWrite8(bmiAddr, BMI160_REG_ACC_RANGE, 0x03);
  delay(10);
  i2cWrite8(bmiAddr, BMI160_REG_GYR_RANGE, 0x03);
  delay(10);

  Serial.print("BMI160 PMU_STATUS: 0x");
  Serial.println(i2cRead8(bmiAddr, BMI160_REG_PMU_STATUS), HEX);

  return true;
}

bool bmi160ReadGyro(float &gxDps, float &gyDps, float &gzDps) {
  uint8_t data[6];

  if (!i2cReadBytes(bmiAddr, BMI160_REG_GYR_X_LSB, data, 6)) {
    return false;
  }

  int16_t rawX = (int16_t)((data[1] << 8) | data[0]);
  int16_t rawY = (int16_t)((data[3] << 8) | data[2]);
  int16_t rawZ = (int16_t)((data[5] << 8) | data[4]);

  gxDps = (float)rawX / BMI160_GYRO_LSB_PER_DPS;
  gyDps = (float)rawY / BMI160_GYRO_LSB_PER_DPS;
  gzDps = (float)rawZ / BMI160_GYRO_LSB_PER_DPS;

  return true;
}

void updateIMU() {
  static uint32_t lastMicros = micros();

  if (!imuOk) {
    return;
  }

  float gx, gy, gz;

  if (!bmi160ReadGyro(gx, gy, gz)) {
    return;
  }

  uint32_t nowMicros = micros();
  float dt = (nowMicros - lastMicros) / 1000000.0f;
  lastMicros = nowMicros;

  if (dt <= 0.0f || dt > 0.1f) {
    return;
  }

  gyroZRawDps = gz;
  gyroZDps = (gz - gyroZBiasDps) * YAW_SIGN;
  yawDeg = wrapDeg(yawDeg + gyroZDps * dt);
}

void zeroPose() {
  poseX = 0.0f;
  poseY = 0.0f;
  yawDeg = 0.0f;
  targetX = 0.0f;
  targetY = 0.0f;
  poseYawTargetDeg = 0.0f;
  resetOuterPID();
}

void calibrateIMU(uint16_t samples) {
  Serial.println("IMU calibration: keep robot still.");

  float sumZ = 0.0f;
  uint16_t good = 0;

  for (uint16_t i = 0; i < samples; i++) {
    float gx, gy, gz;

    if (bmi160ReadGyro(gx, gy, gz)) {
      sumZ += gz;
      good++;
    }

    delay(5);
  }

  if (good < samples / 2) {
    Serial.println("IMU calibration failed.");
    return;
  }

  gyroZBiasDps = sumZ / (float)good;
  zeroPose();

  Serial.print("IMU calibration done. gyroZBiasDps=");
  Serial.println(gyroZBiasDps, 6);
}

// ============================================================
// QUADRATURE DECODER
// ============================================================

void IRAM_ATTR updateQuadrature(int encAPin, int encBPin, volatile long* count, volatile uint8_t* lastState) {
  uint8_t a = digitalRead(encAPin);
  uint8_t b = digitalRead(encBPin);
  uint8_t state = (a << 1) | b;
  uint8_t transition = ((*lastState) << 2) | state;

  if (transition == 0b0001 || transition == 0b0111 || transition == 0b1110 || transition == 0b1000) {
    (*count)++;
  } else if (transition == 0b0010 || transition == 0b1011 || transition == 0b1101 || transition == 0b0100) {
    (*count)--;
  }

  *lastState = state;
}

void IRAM_ATTR isrFR() { updateQuadrature(FR_ENC_A, FR_ENC_B, &encFR, &frLastState); }
void IRAM_ATTR isrFL() { updateQuadrature(FL_ENC_A, FL_ENC_B, &encFL, &flLastState); }
void IRAM_ATTR isrRR() { updateQuadrature(RR_ENC_A, RR_ENC_B, &encRR, &rrLastState); }
void IRAM_ATTR isrRL() { updateQuadrature(RL_ENC_A, RL_ENC_B, &encRL, &rlLastState); }

// ============================================================
