    header{padding:14px 18px;background:#1e1e1e;font-size:20px;font-weight:bold}
    .wrap{padding:14px;display:grid;gap:14px}
    .panel{background:#1b1b1b;border:1px solid #333;border-radius:8px;padding:12px}
    .grid{display:grid;grid-template-columns:repeat(2,minmax(280px,1fr));gap:14px}
    .controls{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;max-width:640px}
    button{padding:12px;border:0;border-radius:7px;font-size:15px;font-weight:bold;background:#2e6be6;color:white;cursor:pointer}
    button:disabled{opacity:.45;cursor:not-allowed}
    .stop{background:#d7263d;grid-column:span 3;font-size:22px;padding:18px}
    .reset{background:#d97706}
    .apply{background:#16a34a}.secondary{background:#444}
    input{padding:8px;border-radius:6px;border:1px solid #555;background:#0f0f0f;color:white;font-size:14px;width:84px}
    .row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px}
    table{width:100%;border-collapse:collapse;font-size:14px}
    td,th{border-bottom:1px solid #333;padding:8px;text-align:right}
    td:first-child,th:first-child{text-align:left}
    canvas{width:100%;height:170px;background:#080808;border:1px solid #333;border-radius:6px}
    .big{font-size:20px;color:#93c5fd;font-weight:bold}.hint{color:#aaa;font-size:13px}.status{color:#22c55e;font-size:13px}.status.error{color:#f87171}
    .robot-state{font-size:22px;color:#facc15;font-weight:bold;margin:8px 0}.reason{color:#fca5a5}
    @media(max-width:760px){.grid{grid-template-columns:1fr}.controls{grid-template-columns:repeat(2,1fr)}.stop{grid-column:span 2}table{font-size:12px}input{width:64px}}
  </style>
</head>
<body>
<header>Mecanum Pose PID - Cascaded Control</header>
<div class="wrap">
  <div class="panel">
    <b>Status</b>
    <div class="row">
      <span>Mode: <span class="big" id="mode">--</span></span>
      <span>X: <span class="big" id="x">--</span></span>
      <span>Y: <span class="big" id="y">--</span></span>
      <span>Yaw: <span class="big" id="yaw">--</span></span>
      <span>IMU: <span class="big" id="imu">--</span></span>
      <span>Control: <span class="big" id="owner">--</span></span>
    </div>
    <div class="row">
      <span>Current waypoint X: <span id="tx">--</span></span>
      <span>Current waypoint Y: <span id="ty">--</span></span>
      <span>Current waypoint Yaw: <span id="tyaw">--</span></span>
      <span>cmd vx: <span id="cvx">--</span></span>
      <span>cmd vy: <span id="cvy">--</span></span>
      <span>cmd wz: <span id="cwz">--</span></span>
      <span>Odom X scale: <span id="odomx">--</span></span>
      <span>Odom Y scale: <span id="odomy">--</span></span>
    </div>
    <div class="row">
      <span>Final destination X: <span class="big" id="goalX">--</span></span>
      <span>Final destination Y: <span class="big" id="goalY">--</span></span>
      <span>Final destination Yaw: <span class="big" id="goalYaw">--</span></span>
      <span class="hint">The current waypoint changes during avoidance; the final destination does not.</span>
    </div>
  </div>

  <div class="panel">
    <b>Obstacle Avoidance Status</b>
    <div id="robotState" class="robot-state">Waiting for ROS obstacle supervisor</div>
    <div class="row">
      <span>Internal state: <span id="robotStateCode">--</span></span>
      <span>Front: <span id="obsFront">--</span> cm</span>
      <span>Left: <span id="obsLeft">--</span> cm</span>
      <span>Right: <span id="obsRight">--</span> cm</span>
      <span>Reset needed: <span id="resetNeeded">--</span></span>
    </div>
    <div id="robotReason" class="reason"></div>
  </div>

  <div class="panel">
    <b>Pose Command</b>
    <div class="row">
      <label>X m</label><input id="targetX" type="number" value="0.20" step="0.01">
      <label>Y m</label><input id="targetY" type="number" value="0.00" step="0.01">
      <label>Yaw deg</label><input id="targetYaw" type="number" value="0" step="1">
      <button id="goPoseButton" class="apply" onclick="goPose()">Go To Pose</button>
      <button class="reset ros-only" onclick="resetTrial()">Reset Trial (Stay Stopped)</button>
      <button class="secondary" onclick="zeroPose()">Zero Pose</button>
      <button class="secondary" onclick="imuCal()">IMU Cal</button>
      <span id="commandStatus" class="status"></span>
    </div>
    <div class="controls">
      <button class="direct-control" onclick="manual('fwd')">Forward</button>
      <button class="direct-control" onclick="manual('cw')">CW</button>
      <button class="direct-control" onclick="manual('right')">Right</button>
      <button class="direct-control" onclick="manual('left')">Left</button>
      <button class="direct-control" onclick="manual('ccw')">CCW</button>
      <button class="direct-control" onclick="manual('back')">Backward</button>
      <button class="stop" onclick="stopRobot()">STOP</button>
    </div>
    <div class="row">
      <label>Manual speed rad/s</label><input id="manualSpeed" type="number" value="3.0" step="0.1">
      <span class="hint">With ROS active, Go To Pose and Reset Trial pass through obstacle safety. Manual buttons are disabled.</span>
    </div>
  </div>

  <div class="panel">
    <div class="row">
      <b>Outer Loop Tuning</b>
      <button class="apply direct-control" onclick="applyOuter()">Apply Outer</button>
      <button class="direct-control" onclick="loadOuter()">Reload</button>
      <span id="outerStatus" class="status"></span>
    </div>
    <table>
      <tbody id="outerBody"></tbody>
    </table>
  </div>

  <div class="panel">
    <b>Wheel Data</b>
    <table>
      <thead><tr><th>Wheel</th><th>Target</th><th>Actual</th><th>Error</th><th>Raw</th><th>D</th><th>PWM</th></tr></thead>
      <tbody id="wheelBody"></tbody>
    </table>
  </div>

  <div class="panel">
    <div class="row">
      <b>Inner Wheel Tuning</b>
      <button class="apply direct-control" onclick="applyWheelParams()">Apply Wheels</button>
      <button class="direct-control" onclick="loadWheelParams()">Reload</button>
      <span id="wheelStatus" class="status"></span>
    </div>
    <table>
      <thead><tr><th>Wheel</th><th>Kp</th><th>Ki</th><th>Kd</th><th>Base</th><th>Max</th><th>I Lim</th></tr></thead>
      <tbody id="paramsBody"></tbody>
    </table>
  </div>

  <div class="grid">
    <div class="panel"><b>X Response</b><canvas id="plotX"></canvas></div>
    <div class="panel"><b>Y Response</b><canvas id="plotY"></canvas></div>
    <div class="panel"><b>Yaw Response</b><canvas id="plotYaw"></canvas></div>
    <div class="panel"><b>Wheel Speeds</b><canvas id="plotWheel"></canvas></div>
  </div>
</div>

<script>
const wheels=["FL","FR","RL","RR"];
const wheelParams=["kp","ki","kd","base","max","ilim"];
const outerParams=[
  ["kpx","Kp X"],["kix","Ki X"],["kdx","Kd X"],
  ["kpy","Kp Y"],["kiy","Ki Y"],["kdy","Kd Y"],
  ["yawkp","Yaw Kp"],["yawki","Yaw Ki"],["yawkd","Yaw Kd"],
  ["maxvx","Max vx"],["maxvy","Max vy"],["maxwz","Max wz"],
  ["odomx","Odom X scale"],["odomy","Odom Y scale"],
  ["postol","Pos tol"],["yawtol","Yaw tol"],
  ["posilim","Pos I lim"],["yawilim","Yaw I lim"],["yawsign","Yaw sign"]
];
const hist={x:[],tx:[],y:[],ty:[],yaw:[],tyaw:[],fl:[],fr:[],rl:[],rr:[]};
const maxPoints=150;
let commandBusy=0;
let rosActive=false;
function val(id){return parseFloat(document.getElementById(id).value||"0")}
function push(a,v){a.push(v);if(a.length>maxPoints)a.shift()}
function withGuiSource(url){return url+(url.includes("?")?"&":"?")+"source=gui"}
function updateOwnership(active){
  rosActive=active;
  document.getElementById("owner").textContent=active?"ROS":"GUI";
  document.querySelectorAll(".direct-control").forEach(button=>button.disabled=active);
  document.querySelectorAll(".ros-only").forEach(button=>button.disabled=!active);
  if(!active)document.getElementById("goPoseButton").disabled=false;
}
async function fetchTimed(url,timeoutMs=1000){
  const controller=new AbortController();
  const timer=setTimeout(()=>controller.abort(),timeoutMs);
  try{return await fetch(withGuiSource(url),{cache:"no-store",signal:controller.signal})}
  finally{clearTimeout(timer)}
}
async function sendCommand(url,label,timeoutMs=1000){
  const status=document.getElementById("commandStatus");
  if(commandBusy>0&&label!=="STOP"){
    status.classList.add("error");
    status.textContent="Wait for the current request or press STOP";
    return;
  }
  commandBusy++;
  status.classList.remove("error");
  status.textContent=`Sending ${label}...`;
  try{
    const response=await fetchTimed(url,timeoutMs);
    if(!response.ok)throw new Error(`HTTP ${response.status}`);
    status.textContent=`${label} acknowledged`;
  }catch(error){
    status.classList.add("error");
    status.textContent=`${label} failed: ${error.name==="AbortError"?"timeout":error.message}`;
  }finally{
    commandBusy=Math.max(0,commandBusy-1);
  }
}
function operatorUrl(action,extra=""){return `/operatorRequest?action=${action}${extra}`}
function goPose(){
  if(rosActive){
    sendCommand(operatorUrl("pose",`&x=${val("targetX")}&y=${val("targetY")}&yaw=${val("targetYaw")}`),"Pose request");
  }else{
    sendCommand(`/pose?x=${val("targetX")}&y=${val("targetY")}&yaw=${val("targetYaw")}`,"Pose");
  }
}
function resetTrial(){sendCommand(operatorUrl("reset_trial"),"Reset Trial")}
function zeroPose(){rosActive?sendCommand(operatorUrl("zero_pose"),"Zero pose request"):sendCommand("/zeroPose","Zero pose")}
function imuCal(){rosActive?sendCommand(operatorUrl("imu_cal"),"IMU calibration request"):sendCommand("/imucal","IMU calibration",8000)}
function stopRobot(){sendCommand("/stop","STOP")}
function manual(c){sendCommand(`/move?cmd=${c}&s=${val("manualSpeed")}`,c)}
function showDistance(value){return value===null||value===undefined||value===""?"--":Number(value).toFixed(1)}
function updateRobotStatus(status){
  if(!status)return;
  document.getElementById("robotState").textContent=status.text||"Waiting for status";
  document.getElementById("robotStateCode").textContent=status.state||"--";
  document.getElementById("obsFront").textContent=showDistance(status.front);
  document.getElementById("obsLeft").textContent=showDistance(status.left);
  document.getElementById("obsRight").textContent=showDistance(status.right);
  document.getElementById("resetNeeded").textContent=status.resetRequired?"YES":"NO";
  document.getElementById("robotReason").textContent=status.reason?`Reason: ${status.reason}`:"";
  document.getElementById("goalX").textContent=status.finalTarget&&status.finalTarget.x!==null?Number(status.finalTarget.x).toFixed(3):"--";
  document.getElementById("goalY").textContent=status.finalTarget&&status.finalTarget.y!==null?Number(status.finalTarget.y).toFixed(3):"--";
  document.getElementById("goalYaw").textContent=status.finalTarget&&status.finalTarget.yaw!==null?Number(status.finalTarget.yaw).toFixed(1):"--";
  if(rosActive){
    const acceptsPose=status.state==="READY"||status.state==="CLEAR";
    document.getElementById("goPoseButton").disabled=!acceptsPose||Boolean(status.resetRequired);
  }
}
function draw(id, series){
  const c=document.getElementById(id),ctx=c.getContext("2d"),dpr=window.devicePixelRatio||1,w=c.clientWidth,h=c.clientHeight;
  if(c.width!==w*dpr||c.height!==h*dpr){c.width=w*dpr;c.height=h*dpr}
  ctx.setTransform(dpr,0,0,dpr,0,0);ctx.clearRect(0,0,w,h);ctx.strokeStyle="#333";ctx.lineWidth=1;
  for(let i=0;i<5;i++){let y=h*i/4;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(w,y);ctx.stroke()}
  let vals=[];series.forEach(s=>vals=vals.concat(s.data));let m=Math.max(0.1,...vals.map(v=>Math.abs(v)));
  series.forEach(s=>{ctx.strokeStyle=s.color;ctx.lineWidth=2;ctx.beginPath();s.data.forEach((v,i)=>{let x=i*w/(maxPoints-1),y=h/2-(v/m)*(h*0.42);if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y)});ctx.stroke()});
}
async function poll(){
  if(commandBusy>0){setTimeout(poll,100);return}
  try{
    const r=await fetchTimed("/data",800);const d=await r.json();
    document.getElementById("mode").textContent=d.poseMode?"POSE":"MANUAL";
    document.getElementById("x").textContent=d.pose.x.toFixed(3);
    document.getElementById("y").textContent=d.pose.y.toFixed(3);
    document.getElementById("yaw").textContent=d.pose.yaw.toFixed(1);
    document.getElementById("imu").textContent=d.imu?"OK":"NO";
    updateOwnership(Boolean(d.rosActive));
    updateRobotStatus(d.rosStatus);
    document.getElementById("tx").textContent=d.target.x.toFixed(3);
    document.getElementById("ty").textContent=d.target.y.toFixed(3);
    document.getElementById("tyaw").textContent=d.target.yaw.toFixed(1);
    document.getElementById("cvx").textContent=d.cmd.vx.toFixed(3);
    document.getElementById("cvy").textContent=d.cmd.vy.toFixed(3);
    document.getElementById("cwz").textContent=d.cmd.wz.toFixed(3);
    document.getElementById("odomx").textContent=d.odom.x.toFixed(3);
    document.getElementById("odomy").textContent=d.odom.y.toFixed(3);
    push(hist.x,d.pose.x);push(hist.tx,d.target.x);push(hist.y,d.pose.y);push(hist.ty,d.target.y);push(hist.yaw,d.pose.yaw/90);push(hist.tyaw,d.target.yaw/90);
    let html="";
    for(const w of wheels){const q=d.wheels[w];html+=`<tr><td>${w}</td><td>${q.t.toFixed(2)}</td><td>${q.a.toFixed(2)}</td><td>${(q.t-q.a).toFixed(2)}</td><td>${q.raw.toFixed(2)}</td><td>${q.d}</td><td>${q.pwm}</td></tr>`}
    document.getElementById("wheelBody").innerHTML=html;
    push(hist.fl,d.wheels.FL.a);push(hist.fr,d.wheels.FR.a);push(hist.rl,d.wheels.RL.a);push(hist.rr,d.wheels.RR.a);
    draw("plotX",[{data:hist.tx,color:"#ffcc00"},{data:hist.x,color:"#22c55e"}]);
    draw("plotY",[{data:hist.ty,color:"#ffcc00"},{data:hist.y,color:"#22c55e"}]);
    draw("plotYaw",[{data:hist.tyaw,color:"#ffcc00"},{data:hist.yaw,color:"#22c55e"}]);
    draw("plotWheel",[{data:hist.fl,color:"#22c55e"},{data:hist.fr,color:"#38bdf8"},{data:hist.rl,color:"#f97316"},{data:hist.rr,color:"#e879f9"}]);
  }catch(e){}
  setTimeout(poll,rosActive?1000:400);
}
function makeWheelTable(data){
  let html="";
  for(const w of wheels){html+=`<tr><td>${w}</td>`;for(const p of wheelParams){html+=`<td><input id="${w}_${p}" type="number" step="0.01" value="${data[w][p]}"></td>`}html+="</tr>"}
  document.getElementById("paramsBody").innerHTML=html;
}
async function loadWheelParams(){commandBusy++;try{const r=await fetchTimed("/params");makeWheelTable(await r.json());document.getElementById("wheelStatus").textContent="Loaded"}catch(e){document.getElementById("wheelStatus").textContent="Load failed"}finally{commandBusy=Math.max(0,commandBusy-1)}}
async function applyWheelParams(){commandBusy++;document.getElementById("wheelStatus").textContent="Applying...";try{for(const w of wheels){for(const p of wheelParams){await fetchTimed(`/setParam?wheel=${w}&param=${p}&value=${document.getElementById(`${w}_${p}`).value}`)}}document.getElementById("wheelStatus").textContent="Applied"}catch(e){document.getElementById("wheelStatus").textContent="Apply failed"}finally{commandBusy=Math.max(0,commandBusy-1)}}
function makeOuterTable(data){
  let html="";
  for(let i=0;i<outerParams.length;i+=3){html+="<tr>";for(let j=0;j<3;j++){const item=outerParams[i+j];if(item){html+=`<td>${item[1]}</td><td><input id="outer_${item[0]}" type="number" step="0.001" value="${data[item[0]]}"></td>`}}html+="</tr>"}
  document.getElementById("outerBody").innerHTML=html;
}
async function loadOuter(){commandBusy++;try{const r=await fetchTimed("/outer");makeOuterTable(await r.json());document.getElementById("outerStatus").textContent="Loaded"}catch(e){document.getElementById("outerStatus").textContent="Load failed"}finally{commandBusy=Math.max(0,commandBusy-1)}}
async function applyOuter(){commandBusy++;document.getElementById("outerStatus").textContent="Applying...";try{for(const p of outerParams){await fetchTimed(`/setOuter?param=${p[0]}&value=${document.getElementById(`outer_${p[0]}`).value}`)}document.getElementById("outerStatus").textContent="Applied"}catch(e){document.getElementById("outerStatus").textContent="Apply failed"}finally{commandBusy=Math.max(0,commandBusy-1)}}
async function initialize(){updateOwnership(false);await loadWheelParams();await loadOuter();poll()}
initialize();
</script>
</body>
</html>
)rawliteral";

// ============================================================
// JSON HELPERS + ROUTES
// ============================================================

bool requestIsRos() {
  return server.hasArg("source")
      && server.arg("source") == "ros"
      && server.hasArg("controller")
      && server.arg("controller") == ROS_CONTROL_TOKEN;
}

bool requestIsGui() {
  return server.hasArg("source") && server.arg("source") == "gui";
}

String jsonEscaped(const String& value) {
  String escaped;
  escaped.reserve(value.length() + 8);
  for (size_t i = 0; i < value.length(); i++) {
    char c = value.charAt(i);
    if (c == '\\' || c == '"') {
      escaped += '\\';
      escaped += c;
    } else if (c == '\n') {
      escaped += "\\n";
    } else if (c != '\r') {
      escaped += c;
    }
  }
  return escaped;
}

void noteRosContact() {
  if (requestIsRos()) {
    lastRosContactMs = millis();
    rosOwnershipObserved = true;
  }
}

bool rosControlActive() {
  return lastRosContactMs != 0
      && (uint32_t)(millis() - lastRosContactMs) < ROS_OWNER_TIMEOUT_MS;
}

bool rejectGuiCommandWhileRosActive() {
  if (requestIsRos()) {
    noteRosContact();
    return false;
  }

  if (!requestIsGui()) {
    server.send(403, "text/plain", "Unknown controller");
    return true;
  }

  if (rosControlActive()) {
    server.send(423, "text/plain", "ROS control active");
    return true;
  }

  return false;
}

void maintainRosOwnership() {
  if (
    rosOwnershipObserved
    && lastRosContactMs != 0
    && (uint32_t)(millis() - lastRosContactMs) >= ROS_OWNER_TIMEOUT_MS
  ) {
    stopAll();
    rosOwnershipObserved = false;
    lastRosContactMs = 0;
    Serial.println("ROS heartbeat lost. Robot stopped; GUI control restored.");
  }
}

void sendWheelJsonPart(const Wheel& w, String& json) {
  json += "\"";
  json += w.name;
  json += "\":{";
  json += "\"t\":" + String(w.targetRadS, 3);
  json += ",\"a\":" + String(w.filtRadS, 3);
  json += ",\"raw\":" + String(w.rawRadS, 3);
  json += ",\"d\":" + String(w.lastDelta);
  json += ",\"pwm\":" + String(w.appliedPWM);
  json += "}";
}

void handleData() {
  noteRosContact();

  String json = "{";
  json += "\"poseMode\":" + String(poseMode ? "true" : "false") + ",";
  json += "\"imu\":" + String(imuOk ? "true" : "false") + ",";
  json += "\"rosActive\":" + String(rosControlActive() ? "true" : "false") + ",";
  json += "\"guiStopCount\":" + String(guiStopCount) + ",";
  json += "\"operatorRequest\":{";
  json += "\"id\":" + String(operatorRequestId);
  json += ",\"pending\":" + String(operatorRequestPending ? "true" : "false");
  json += ",\"type\":\"" + jsonEscaped(operatorRequestType) + "\"";
  json += ",\"x\":" + String(operatorRequestX, 4);
  json += ",\"y\":" + String(operatorRequestY, 4);
  json += ",\"yaw\":" + String(operatorRequestYaw, 3);
  json += "},";
  json += "\"rosStatus\":{";
  json += "\"state\":\"" + jsonEscaped(rosStatusState) + "\"";
  json += ",\"text\":\"" + jsonEscaped(rosStatusText) + "\"";
  json += ",\"reason\":\"" + jsonEscaped(rosStatusReason) + "\"";
  json += ",\"front\":";
  json += rosStatusFront.length() ? rosStatusFront : "null";
  json += ",\"left\":";
  json += rosStatusLeft.length() ? rosStatusLeft : "null";
  json += ",\"right\":";
  json += rosStatusRight.length() ? rosStatusRight : "null";
  json += ",\"finalTarget\":{\"x\":";
  json += rosStatusGoalX.length() ? rosStatusGoalX : "null";
  json += ",\"y\":";
  json += rosStatusGoalY.length() ? rosStatusGoalY : "null";
  json += ",\"yaw\":";
  json += rosStatusGoalYaw.length() ? rosStatusGoalYaw : "null";
  json += "}";
  json += ",\"resetRequired\":" + String(rosStatusResetRequired ? "true" : "false");
  json += ",\"ageMs\":" + String(rosStatusUpdatedMs == 0 ? 0 : millis() - rosStatusUpdatedMs);
  json += "},";
  json += "\"pose\":{\"x\":" + String(poseX, 4) + ",\"y\":" + String(poseY, 4) + ",\"yaw\":" + String(yawDeg, 3) + "},";
  json += "\"target\":{\"x\":" + String(targetX, 4) + ",\"y\":" + String(targetY, 4) + ",\"yaw\":" + String(poseYawTargetDeg, 3) + "},";
  json += "\"cmd\":{\"vx\":" + String(cmdVx, 4) + ",\"vy\":" + String(cmdVy, 4) + ",\"wz\":" + String(cmdWz, 4) + "},";
  json += "\"odom\":{\"x\":" + String(ODOM_X_SCALE, 4) + ",\"y\":" + String(ODOM_Y_SCALE, 4) + "},";
  json += "\"wheels\":{";
  sendWheelJsonPart(FL, json); json += ",";
  sendWheelJsonPart(FR, json); json += ",";
  sendWheelJsonPart(RL, json); json += ",";
  sendWheelJsonPart(RR, json);
  json += "}}";

  server.send(200, "application/json", json);
}

void sendParamJsonPart(const Wheel& w, String& json) {
  json += "\"";
  json += w.name;
  json += "\":{";
  json += "\"kp\":" + String(w.Kp, 3);
  json += ",\"ki\":" + String(w.Ki, 3);
  json += ",\"kd\":" + String(w.Kd, 3);
  json += ",\"base\":" + String(w.basePWM);
  json += ",\"max\":" + String(w.maxPWM);
  json += ",\"ilim\":" + String(w.integralLimit, 3);
  json += "}";
}

void handleParams() {
  String json = "{";
  sendParamJsonPart(FL, json); json += ",";
  sendParamJsonPart(FR, json); json += ",";
  sendParamJsonPart(RL, json); json += ",";
  sendParamJsonPart(RR, json);
  json += "}";

  server.send(200, "application/json", json);
}

void handleOuter() {
  String json = "{";
  json += "\"kpx\":" + String(posKpX, 4);
  json += ",\"kix\":" + String(posKiX, 4);
  json += ",\"kdx\":" + String(posKdX, 4);
  json += ",\"kpy\":" + String(posKpY, 4);
  json += ",\"kiy\":" + String(posKiY, 4);
  json += ",\"kdy\":" + String(posKdY, 4);
  json += ",\"yawkp\":" + String(yawKp, 4);
  json += ",\"yawki\":" + String(yawKi, 4);
  json += ",\"yawkd\":" + String(yawKd, 4);
  json += ",\"maxvx\":" + String(MAX_VX, 4);
  json += ",\"maxvy\":" + String(MAX_VY, 4);
  json += ",\"maxwz\":" + String(MAX_WZ, 4);
  json += ",\"odomx\":" + String(ODOM_X_SCALE, 4);
  json += ",\"odomy\":" + String(ODOM_Y_SCALE, 4);
  json += ",\"postol\":" + String(POS_TOL_M, 4);
  json += ",\"yawtol\":" + String(YAW_TOL_DEG, 4);
  json += ",\"posilim\":" + String(posIntegralLimit, 4);
  json += ",\"yawilim\":" + String(yawIntegralLimit, 4);
  json += ",\"yawsign\":" + String(YAW_SIGN, 1);
  json += "}";

  server.send(200, "application/json", json);
}

void handleSetParam() {
  if (rejectGuiCommandWhileRosActive()) {
    return;
  }

  Wheel* w = getWheelByName(server.arg("wheel"));

  if (w == nullptr) {
    server.send(400, "text/plain", "Unknown wheel");
    return;
  }

  if (!setWheelParam(*w, server.arg("param"), server.arg("value").toFloat())) {
    server.send(400, "text/plain", "Unknown parameter");
    return;
  }

  server.send(200, "text/plain", "OK");
}

void handleSetOuter() {
  if (rejectGuiCommandWhileRosActive()) {
    return;
  }

  if (!setOuterParam(server.arg("param"), server.arg("value").toFloat())) {
    server.send(400, "text/plain", "Unknown outer parameter");
    return;
  }

  server.send(200, "text/plain", "OK");
}

void handleOperatorRequest() {
  if (!requestIsGui()) {
    server.send(403, "text/plain", "GUI source required");
    return;
  }
  if (!rosControlActive()) {
    server.send(503, "text/plain", "ROS obstacle supervisor is not connected");
    return;
  }
  if (operatorRequestPending) {
    server.send(409, "text/plain", "Previous operator request is still pending");
    return;
  }

  String action = server.arg("action");
  if (
    action != "pose"
    && action != "reset_trial"
    && action != "zero_pose"
    && action != "imu_cal"
  ) {
    server.send(400, "text/plain", "Unsupported operator action");
    return;
  }

  operatorRequestType = action;
  if (action == "pose") {
    if (!server.hasArg("x") || !server.hasArg("y") || !server.hasArg("yaw")) {
      server.send(400, "text/plain", "Pose requires x, y, and yaw");
      return;
    }
    operatorRequestX = constrain(server.arg("x").toFloat(), -5.0f, 5.0f);
    operatorRequestY = constrain(server.arg("y").toFloat(), -5.0f, 5.0f);
    operatorRequestYaw = constrain(server.arg("yaw").toFloat(), -180.0f, 180.0f);
  } else {
    operatorRequestX = 0.0f;
    operatorRequestY = 0.0f;
    operatorRequestYaw = 0.0f;
  }

  operatorRequestId++;
  operatorRequestPending = true;
  server.send(202, "text/plain", "Queued for ROS obstacle supervisor");
}

void handleOperatorAck() {
  if (!requestIsRos()) {
    server.send(403, "text/plain", "ROS controller required");
    return;
  }
  noteRosContact();

  uint32_t acknowledgedId = (uint32_t)server.arg("id").toInt();
  if (operatorRequestPending && acknowledgedId == operatorRequestId) {
    operatorRequestPending = false;
    server.send(200, "text/plain", "ACK");
    return;
  }
  server.send(409, "text/plain", "Request id does not match");
}

void handleRosStatus() {
  if (!requestIsRos()) {
    server.send(403, "text/plain", "ROS controller required");
    return;
  }
  noteRosContact();

  rosStatusState = server.arg("state");
  rosStatusText = server.arg("text");
  rosStatusReason = server.arg("reason");
  rosStatusFront = server.arg("front");
  rosStatusLeft = server.arg("left");
  rosStatusRight = server.arg("right");
  rosStatusGoalX = server.arg("goal_x");
  rosStatusGoalY = server.arg("goal_y");
  rosStatusGoalYaw = server.arg("goal_yaw");
  rosStatusResetRequired = server.arg("reset") == "1";
  rosStatusUpdatedMs = millis();
  server.send(200, "text/plain", "STATUS");
}

void handlePose() {
  if (rejectGuiCommandWhileRosActive()) {
    return;
  }

  float x = server.arg("x").toFloat();
  float y = server.arg("y").toFloat();
  float yaw = server.arg("yaw").toFloat();

  x = constrain(x, -5.0f, 5.0f);
  y = constrain(y, -5.0f, 5.0f);
  yaw = constrain(yaw, -180.0f, 180.0f);

  startPoseMove(x, y, yaw);
  server.send(200, "text/plain", "POSE");
}

void handleMove() {
  if (rejectGuiCommandWhileRosActive()) {
    return;
  }

  poseMode = false;
  resetOuterPID();

  String cmd = server.arg("cmd");
  float s = fabsf(server.arg("s").toFloat());
  s = constrain(s, 0.0f, 12.0f);

  if (cmd == "fwd") {
    setWheelTarget(FL, +s); setWheelTarget(FR, +s); setWheelTarget(RL, +s); setWheelTarget(RR, +s);
  } else if (cmd == "back") {
    setWheelTarget(FL, -s); setWheelTarget(FR, -s); setWheelTarget(RL, -s); setWheelTarget(RR, -s);
  } else if (cmd == "right") {
    setWheelTarget(FL, +s); setWheelTarget(FR, -s); setWheelTarget(RL, -s); setWheelTarget(RR, +s);
  } else if (cmd == "left") {
    setWheelTarget(FL, -s); setWheelTarget(FR, +s); setWheelTarget(RL, +s); setWheelTarget(RR, -s);
  } else if (cmd == "cw") {
    setWheelTarget(FL, +s); setWheelTarget(FR, -s); setWheelTarget(RL, +s); setWheelTarget(RR, -s);
  } else if (cmd == "ccw") {
    setWheelTarget(FL, -s); setWheelTarget(FR, +s); setWheelTarget(RL, -s); setWheelTarget(RR, +s);
  }

  server.send(200, "text/plain", "OK");
}

void handleStop() {
  if (requestIsRos()) {
    noteRosContact();
  } else if (requestIsGui()) {
    guiStopCount++;
  } else {
    server.send(403, "text/plain", "Unknown controller");
    return;
  }
  stopAll();
  server.send(200, "text/plain", "STOP");
}

void handleZeroPose() {
  if (rejectGuiCommandWhileRosActive()) {
    return;
  }

  stopAll();
  zeroPose();
  server.send(200, "text/plain", "ZERO");
}

void handleImuCal() {
  if (rejectGuiCommandWhileRosActive()) {
    return;
  }

  stopAll();
  calibrateIMU(1200);
  server.send(200, "text/plain", "IMU CAL");
}

