// ============================================================
// UTILITY
// ============================================================

float wrapDeg(float a) {
  while (a > 180.0f) a -= 360.0f;
  while (a < -180.0f) a += 360.0f;
  return a;
}

float degToRad(float d) {
  return d * PI / 180.0f;
}

float radToDeg(float r) {
  return r * 180.0f / PI;
}

