Wheel* getWheelByName(String name) {
  name.toUpperCase();

  if (name == "FR") return &FR;
  if (name == "FL") return &FL;
  if (name == "RR") return &RR;
  if (name == "RL") return &RL;

  return nullptr;
}

bool setWheelParam(Wheel& w, String param, float value) {
  param.toLowerCase();

  if (param == "kp") w.Kp = value;
  else if (param == "ki") w.Ki = value;
  else if (param == "kd") w.Kd = value;
  else if (param == "base") w.basePWM = constrain((int)value, 0, PWM_ABS_LIMIT);
  else if (param == "max") w.maxPWM = constrain((int)value, 0, PWM_ABS_LIMIT);
  else if (param == "ilim") w.integralLimit = value;
  else return false;

  resetWheelPID(w);
  return true;
}

bool setOuterParam(String param, float value) {
  param.toLowerCase();

  if (param == "kpx") posKpX = value;
  else if (param == "kix") posKiX = value;
  else if (param == "kdx") posKdX = value;
  else if (param == "kpy") posKpY = value;
  else if (param == "kiy") posKiY = value;
  else if (param == "kdy") posKdY = value;
  else if (param == "yawkp") yawKp = value;
  else if (param == "yawki") yawKi = value;
  else if (param == "yawkd") yawKd = value;
  else if (param == "maxvx") MAX_VX = constrain(value, 0.01f, 1.0f);
  else if (param == "maxvy") MAX_VY = constrain(value, 0.01f, 1.0f);
  else if (param == "maxwz") MAX_WZ = constrain(value, 0.05f, 3.0f);
  else if (param == "odomx") ODOM_X_SCALE = constrain(value, 0.50f, 1.50f);
  else if (param == "odomy") ODOM_Y_SCALE = constrain(value, 0.50f, 1.50f);
  else if (param == "postol") POS_TOL_M = constrain(value, 0.001f, 0.25f);
  else if (param == "yawtol") YAW_TOL_DEG = constrain(value, 0.2f, 20.0f);
  else if (param == "posilim") posIntegralLimit = constrain(value, 0.0f, 5.0f);
  else if (param == "yawilim") yawIntegralLimit = constrain(value, 0.0f, 5.0f);
  else if (param == "yawsign") YAW_SIGN = (value < 0.0f) ? -1.0f : 1.0f;
  else return false;

  resetOuterPID();
  return true;
}

